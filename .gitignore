# Data: the full corpus is ~12MB, small enough to ship in git directly.
# (If corpus grows >100MB later, switch to Git LFS or external storage.)
# We commit corpus.db + tfidf.npz so cloning + deploying works without
# re-running the 2-hour fetch script.
# Exclude only the per-run probe outputs that don't matter for deploy.

# Editor / tools
.vscode/
.idea/
*.swp
.claude/

# OS
.DS_Store
Thumbs.db

# Probe / scratch artifacts
scripts/probe_games_cache.json
scripts/probe_results.csv
scripts/diagnose_output.txt
scripts/real_user_output*.txt

# Visual review screenshots (regenerated from screenshot_*.py scripts).
# Keep just the two used in README.md; everything else is WIP.
screenshots/*
!screenshots/result_taste_desktop.png
!screenshots/result_regret_desktop.png

